[Unit]
Description=0xchou00 Detection Tool
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=__BACKEND_DIR__
EnvironmentFile=__PROJECT_ROOT__/.env
ExecStart=__PROJECT_ROOT__/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
